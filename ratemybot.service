[Unit]
Description=Rate My Bot Runtime Service
Requires=docker.service
After=docker.service
StartLimitBurst=3
StartLimitInterval=0
StartLimitIntervalSec=5

[Service]
Restart=always
WorkingDirectory=/home/amy/comp209-team
ExecStart=/usr/bin/docker run --privileged --mount type=bind,source=/dev,target=/dev docker.github.falmouth.ac.uk/aw295676/comp209-team/runtime:dev

[Install]
WantedBy=default.target
